[Unit]
Description=nbAPI Data Management Daemon
After=network.target
Wants=network.target

[Service]
Type=simple
User=nbapi
Group=nbapi
WorkingDirectory=/opt/nbapi
ExecStart=/opt/nbapi/datamanagementd \
  -socket-path /tmp/nbapi-datamanagement.sock \
  -sqlite-path /var/lib/nbapi/datamanagement/datamanagementd.db \
  -version 1.0.0
Restart=always
RestartSec=5s
LimitNOFILE=100000
NoNewPrivileges=true
PrivateTmp=false

[Install]
WantedBy=multi-user.target
