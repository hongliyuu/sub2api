# =============================================================================
# Sub2API · Zeabur 环境变量模板
# =============================================================================
# 在 Zeabur 面板的 Variables 区一次性贴入。${SVC_VAR} 形式是 Zeabur 服务间引用，
# 部署时由平台自动注入对应数据库 / Redis 服务的连接信息，不要硬编码。
#
# 所有标 [必填] 的不能省；标 [必填|生成] 的需用 openssl rand 自己生成强随机值
# 后再贴；标 [可选] 的有合理默认。
# =============================================================================

# ----------------------------- 服务监听 -----------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=production

# ----------------------------- 数据库（引用 Zeabur Postgres 服务）-----------------------------
# [必填] 在 Zeabur 项目内先添加 Postgres 服务，下面占位会自动解析。
DATABASE_HOST=${POSTGRES_HOST}
DATABASE_PORT=${POSTGRES_PORT}
DATABASE_USER=${POSTGRES_USERNAME}
DATABASE_PASSWORD=${POSTGRES_PASSWORD}
DATABASE_DBNAME=${POSTGRES_DATABASE}
DATABASE_SSLMODE=disable

# ----------------------------- Redis（引用 Zeabur Redis 服务）-----------------------------
# [必填] 在 Zeabur 项目内先添加 Redis 服务。
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=${REDIS_PORT}
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_DB=0

# ----------------------------- 安全密钥 -----------------------------
# [必填|生成] 用以下命令生成后填入；切勿用弱口令或示例值。
#   JWT_SECRET:           openssl rand -hex 32
#   TOTP_ENCRYPTION_KEY:  openssl rand -hex 32
# !! 重要 !! TOTP_ENCRYPTION_KEY 一旦丢失，所有用户的 2FA 立即失效。
#           生成后立刻另存到密码管理器，不要只存在 Zeabur 面板里。
JWT_SECRET=
TOTP_ENCRYPTION_KEY=

# ----------------------------- 首次管理员 -----------------------------
# [必填] 仅首次启动注入；改密走管理界面或数据库，不要靠改这里。
# 生成强随机密码：openssl rand -base64 24
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=

# ----------------------------- 自动初始化 -----------------------------
# [必填] true = 首次启动自动建表 + 写入管理员；后续启动幂等。
AUTO_SETUP=true

# ----------------------------- 运行模式 -----------------------------
RUN_MODE=standard
TZ=Asia/Shanghai

# ----------------------------- 可选：DeepSeek 协议选择 -----------------------------
# [可选] 配置了 base_url=https://api.deepseek.com/anthropic 的 DeepSeek 账号
# 默认走 OpenAI Chat Completions 转换路径。设为 0 改走 Anthropic 透传，
# 跨上游切换更稳定（thinking 块由 DeepSeek 自家 anthropic 兼容层处理）。
# SUB2API_DEEPSEEK_TRANSLATION=0
